{
  "name": "agent-skill-porter",
  "version": "7.0.1",
  "description": "A skill lifecycle management CLI for AI agents — Add and manage updates for any Skill, and convert formats across Claude Code and many other agents. Zero config, no extra files needed.",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sk": "./bin/agent-skill-porter",
    "agent-skill-porter": "./bin/agent-skill-porter"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome check --apply .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "tidy": "pnpm format && pnpm lint:fix && pnpm typecheck && pnpm test",
    "prepublishOnly": "pnpm verify && pnpm build",
    "preversion": "pnpm verify",
    "version": "pnpm format && git add -A"
  },
  "files": ["dist", "bin"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": ["claude-code", "gemini-cli", "codex-cli", "agent-skills", "skill-management", "converter", "cli"],
  "author": "hatappo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skill-mill/agent-skill-porter.git"
  },
  "bugs": {
    "url": "https://github.com/skill-mill/agent-skill-porter/issues"
  },
  "homepage": "https://github.com/skill-mill/agent-skill-porter#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "@inquirer/select": "5.1.0",
    "commander": "14.0.0",
    "gray-matter": "4.0.3",
    "picocolors": "1.1.1",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "24.2.0",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "5.9.2",
    "vite": "7.0.6",
    "vitest": "3.2.4"
  },
  "volta": {
    "node": "24.5.0",
    "pnpm": "10.33.0"
  }
}
